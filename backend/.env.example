ENV=production
SECRET_KEY=replace-with-a-long-random-string

# Supabase free tier Postgres connection string (Settings -> Database -> Connection string)
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# Qdrant Cloud free tier (Cluster -> API Keys)
QDRANT_URL=https://xxxx.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Upstash Redis free tier (rediss:// url from Upstash console)
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# Groq free tier API key (console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Optional: Langfuse free tier for LLM observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
